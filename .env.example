# Copy this file to .env and fill in your own values.
# .env should NEVER be committed to git (it's already in .gitignore).

# Random long string used to sign login tokens. Use any long random text.
JWT_SECRET=change-this-to-a-long-random-string

# How many spots the event has
EVENT_CAPACITY=100

# Server port
PORT=3000

# ---- Staff login (used by seed script: npm run seed) ----
STAFF_USERNAME=staff
STAFF_PASSWORD=change-this-password

# ---- Email (SMTP) ----
# If left blank, emails are just logged to the console instead of sent —
# useful while you're building, before you have real credentials.
# Example using Gmail SMTP (you'd need an "app password", not your normal one):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Event Team <no-reply@example.com>"
